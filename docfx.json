{
  "metadata": [
    {
      "src": [
        {
          "files": [
            "NS.UnifiedLoot.csproj"
          ],
          "src": "."
        }
      ],
      "dest": "docs/api",
      "filter": "filterConfig.yml",
      "includePrivateMembers": false,
      "disableGitFeatures": false,
      "disableDefaultFilter": false,
      "noRestore": false,
      "namespaceLayout": "flattened",
      "memberLayout": "samePage",
      "allowCompilationErrors": false
    }
  ],
  "build": {
    "globalMetadata": {
      "_appTitle": "Unified Loot",
      "_appName": "Unified Loot",
      "_appLogoPath": "docs/media/logo.svg",
      "_appFooter": "© 2026 Nicolas Stephan · MIT License",
      "_enableSearch": true,
      "_gitContribute": {
        "repo": "https://github.com/nicolas-stephan/UnifiedLoot",
        "branch": "main"
      }
    },
    "fileMetadata": {
    },
    "content": [
      {
        "files": [
          "**/*.md",
          "**/toc.yml"
        ],
        "src": "docs"
      },
      {
        "files": [
          "**.yml",
          "**/toc.yml"
        ],
        "src": "docs/api"
      }
    ],
    "styles": [
      "styles/main.css"
    ],
    "resource": [
      {
        "files": [
          "images/**"
        ],
        "src": "docs"
      }
    ],
    "output": "_site",
    "markdownEngineProperties": {
      "toc": {
        "levels": "1,2,3"
      }
    },
    "fileMetadataFiles": [],
    "template": [
      "default",
      "modern",
      "template"
    ],
    "postProcessors": [
      "ExtractSearchIndex"
    ],
    "keepFileLink": false,
    "disableGitFeatures": false,
    "fileMetadata": {}
  }
}
